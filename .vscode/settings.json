{
  // Biome를 기본 포맷터로 설정
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,

  // 언어별 Biome 포맷터 명시 (TypeScript/JavaScript/JSON)
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  // ESLint 비활성화 (Biome로 대체)
  "eslint.enable": false,

  // 저장 시 import 정렬 (Biome organizeImports)
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  }
}
