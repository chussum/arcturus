{
  "name": "@arcturus/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ../../scripts/with-secrets.sh bun --watch src/main.ts",
    "start": "bash ../../scripts/with-secrets.sh bun src/main.ts",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@arcturus/shared": "workspace:*",
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/platform-express": "11.0.0",
    "@nestjs/throttler": "6.5.0",
    "adm-zip": "0.5.16",
    "cookie-parser": "1.4.7",
    "dockerode": "4.0.5",
    "drizzle-orm": "0.44.0",
    "http-proxy": "1.18.1",
    "jose": "6.0.0",
    "multer": "2.1.1",
    "nanoid": "5.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7",
    "@types/cookie-parser": "1.4.8",
    "@types/dockerode": "3.3.34",
    "@types/express": "5.0.0",
    "@types/http-proxy": "1.17.16",
    "@types/multer": "1.4.12",
    "@types/node": "25.9.0",
    "bun-types": "1.3.14",
    "drizzle-kit": "0.31.0"
  }
}
