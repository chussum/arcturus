# Arcturus API + gateway — copy to .env and adjust.
# Every value is optional; the defaults below are what you get without a .env.
# (Bun loads .env from this directory automatically.)
#
# Arcturus API + 게이트웨이 — .env로 복사해서 수정하세요.
# 모든 값은 선택이며, 아래 기본값은 .env가 없을 때 적용되는 값입니다.
# (Bun이 이 디렉터리의 .env를 자동으로 로드합니다.)

# Control-plane port — REST API + dashboard.
# 제어 평면 포트 — REST API + 대시보드.
ARCTURUS_PORT=7777

# Separate origin for deployed user apps. Keeping apps off the control-plane
# origin stops an app's JavaScript from riding a logged-in visitor's session
# cookie. Give each instance on a shared host its own value.
# 배포된 사용자 앱 전용 오리진. 앱을 제어 평면과 다른 오리진에 두어, 앱의
# JS가 로그인한 방문자의 세션 쿠키를 가로채지 못하게 합니다. 공유 호스트에서는
# 인스턴스마다 다른 값을 주세요.
ARCTURUS_APPS_PORT=7778

# Where SQLite, static releases and build workspaces live (relative to apps/api).
# SQLite·정적 릴리스·빌드 작업 공간 위치 (apps/api 기준 상대 경로).
ARCTURUS_DATA_DIR=./data

# Dedicated host-port pool for container apps.
# 컨테이너 앱 전용 호스트 포트 풀.
ARCTURUS_PORT_POOL_START=30000
ARCTURUS_PORT_POOL_END=39999

# Upload size limit for deployment archives (MB).
# 배포 아카이브 업로드 크기 제한 (MB).
ARCTURUS_MAX_UPLOAD_MB=256

# Releases kept per app for rollback (older static dirs / images are pruned).
# 앱별 롤백용 릴리스 보관 개수 (초과분의 정적 디렉터리/이미지는 자동 정리).
ARCTURUS_KEEP_RELEASES=5

# Default container memory cap (MB) when an app has no explicit limit, and the
# ceiling a per-app limit (set in the dashboard) may not exceed.
# 앱에 명시적 제한이 없을 때의 컨테이너 기본 메모리 상한(MB)과, 대시보드에서
# 설정하는 앱별 제한이 넘을 수 없는 상한.
ARCTURUS_DEFAULT_MEMORY_MB=1024
ARCTURUS_MAX_MEMORY_MB=4096

# Force deployed containers to run as this user (e.g. 1000:1000) — a hardening
# opt-in. Empty honors the image's own USER (often root).
# 배포 컨테이너를 이 사용자로 강제 실행 (예: 1000:1000) — 하드닝 옵트인.
# 비워두면 이미지의 USER(대개 root)를 따릅니다.
#ARCTURUS_CONTAINER_USER=

# SSH login pre-filled in the dashboard's terminal-access hint, so the docker
# commands read ssh://<this>@host. The host OS account, not an Arcturus username.
# Empty shows a <ssh-user> placeholder. Not a secret — a convenience opt-in.
# 대시보드 터미널 접근 안내에 채워 넣을 SSH 로그인 계정 (호스트 OS 계정, Arcturus
# 사용자명 아님). 비워두면 <ssh-user> 자리표시자를 보여줍니다. 비밀 아님 — 편의 옵트인.
#ARCTURUS_SSH_USER=

# Set when running behind a TLS-terminating reverse proxy (an Express
# `trust proxy` value, e.g. 1 or "loopback"). Without it Secure cookies are
# never set and per-IP rate limits key on the proxy's IP.
# TLS를 종단하는 리버스 프록시 뒤에서 운용할 때 설정 (Express `trust proxy` 값,
# 예: 1 또는 "loopback"). 없으면 Secure 쿠키가 안 붙고 IP별 rate limit이
# 프록시 IP 기준으로 잡힙니다.
#ARCTURUS_TRUST_PROXY=

# Where the Next.js dashboard server listens (proxied under /dashboard).
# Next.js 대시보드 서버 주소 (/dashboard 경로로 프록시됩니다).
#ARCTURUS_DASHBOARD_ORIGIN=http://127.0.0.1:3000

# Cross-compiled CLI binaries served at /install.sh + /cli/* (apps/cli `bun run build:all`).
# /install.sh + /cli/* 로 서빙할 크로스컴파일 CLI 바이너리 위치 (apps/cli에서 `bun run build:all`).
#ARCTURUS_CLI_DIST=../cli/dist/cli
